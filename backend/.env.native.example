# ──────────────────────────────────────────────────────────────────────────────
# Backend — développement NATIF (sans Docker)
# Copier vers backend/.env :
#   cp backend/.env.native.example backend/.env
# Puis ajuster DATABASE_URL si ton Postgres local diffère.
# ──────────────────────────────────────────────────────────────────────────────

DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=dev-secret-change-me-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Postgres sur la machine (pas le hostname Docker "postgres")
DATABASE_URL=postgres://syskern:syskern@127.0.0.1:5432/syskern

# Redis sur la machine (pas le hostname Docker "redis")
REDIS_URL=redis://127.0.0.1:6379/0

# Auth / intégrations — reprendre les valeurs de ton .env actuel si besoin
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

ODOO_API_VERSION=v19
ODOO_BASE_URL=
ODOO_DB_NAME=
ODOO_API_USER=
ODOO_API_PASSWORD=
ODOO_TIMEOUT_SECONDS=30
ODOO_SYNC_HOUR_UTC=3
ODOO_SYNC_ENABLED=false

GAMMA_API_KEY=
GAMMA_TEMPLATE_ID_DEVIS_PROJET=
GAMMA_TEMPLATE_ID_CATALOGUE_TARIFE=
DEEPL_API_KEY=
OPENAI_API_KEY=
