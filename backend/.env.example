# ─────────────────────────────────────────────────────────────────────────────
# Syskern backend — environment variables
# Copy to `.env` and adjust for your local environment.
# In production these are injected by Coolify (or your hosting platform).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=dev-secret-change-me-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Production-only toggles (no effect under config.settings.local)
#   DJANGO_DB_SSLMODE=disable|require|verify-full   (default: disable)
#   DJANGO_SECURE_SSL_REDIRECT=true|false            (default: false — Traefik handles it)
#DJANGO_DB_SSLMODE=disable
#DJANGO_SECURE_SSL_REDIRECT=false

# ─── Database ────────────────────────────────────────────────────────────────
# Docker Compose: host "postgres".  Dev natif (sans Docker): 127.0.0.1 — cf. .env.native.example
DATABASE_URL=postgres://syskern:syskern@postgres:5432/syskern

# ─── Cache / Celery broker ───────────────────────────────────────────────────
# Docker: redis.  Dev natif: redis://127.0.0.1:6379/0
REDIS_URL=redis://redis:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
# MVP1: real Django users + Profile roles (admin/commercial/viewer), session
# login via /api/auth/login. In production this may be delegated to Supabase
# Auth and the JWT verified against SUPABASE_JWT_SECRET.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Odoo (default instance — read by the legacy single-adapter path) ────────
ODOO_API_VERSION=v19
ODOO_BASE_URL=
ODOO_DB_NAME=
ODOO_API_USER=
ODOO_API_PASSWORD=
ODOO_TIMEOUT_SECONDS=60
ODOO_SYNC_HOUR_UTC=3
ODOO_SYNC_ENABLED=false
ODOO_VERIFY_TLS=true

# ─── Odoo v16 (used when api_version="v16") ──────────────────────────────────
ODOO_V16_BASE_URL=
ODOO_V16_DB_NAME=
ODOO_V16_API_USER=
ODOO_V16_API_PASSWORD=
ODOO_V16_VERIFY_TLS=true

# ─── Odoo v19 (used when api_version="v19") ──────────────────────────────────
ODOO_V19_BASE_URL=
ODOO_V19_DB_NAME=
ODOO_V19_API_USER=
ODOO_V19_API_PASSWORD=
ODOO_V19_VERIFY_TLS=true

# ─── Gunicorn (prod only) ────────────────────────────────────────────────────
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# ─── Celery worker / beat (prod only) ────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_LOGLEVEL=info
CELERY_BEAT_LOGLEVEL=info

# ─── External APIs ───────────────────────────────────────────────────────────
GAMMA_API_KEY=
GAMMA_TEMPLATE_ID_DEVIS_PROJET=
GAMMA_TEMPLATE_ID_CATALOGUE_TARIFE=

DEEPL_API_KEY=
OPENAI_API_KEY=
