# ──────────────────────────────────────────────────────────────────────────────
# Syskern backend — environment variables
# Copy to `.env` and adjust for your local environment.
# Production values are injected through the host environment / Supabase.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=dev-secret-change-me-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local: docker-compose Postgres.  Production: Supabase Postgres URL.
DATABASE_URL=postgres://syskern:syskern@postgres:5432/syskern

# ─── Cache / Celery broker ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# MVP1: real Django users + Profile roles (admin/commercial/viewer), session
# login via /api/auth/login. In production this is delegated to Supabase Auth
# and we verify the JWT against SUPABASE_JWT_SECRET.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Odoo ─────────────────────────────────────────────────────────────────────
ODOO_API_VERSION=v19
ODOO_BASE_URL=
ODOO_DB_NAME=
ODOO_API_USER=
ODOO_API_PASSWORD=
ODOO_TIMEOUT_SECONDS=30
ODOO_SYNC_HOUR_UTC=3
ODOO_SYNC_ENABLED=false

# ─── External APIs ────────────────────────────────────────────────────────────
GAMMA_API_KEY=
GAMMA_TEMPLATE_ID_DEVIS_PROJET=
GAMMA_TEMPLATE_ID_CATALOGUE_TARIFE=

DEEPL_API_KEY=
OPENAI_API_KEY=
